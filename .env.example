# =============================================================================
# dorinelpuia.ro — env vars for contact form handler (/api/submit)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. Never commit `.env` to git
# (it's already in .gitignore). In Vercel, add the SAME keys via
# Dashboard → Settings → Environment Variables (or `vercel env add`).
# =============================================================================


# -----------------------------------------------------------------------------
# GOOGLE SHEETS — where form submissions are stored
# -----------------------------------------------------------------------------
#
# HOW TO OBTAIN:
#
# 1) Go to https://console.cloud.google.com/ and create (or pick) a project.
# 2) Enable the Google Sheets API: APIs & Services → Library → search
#    "Google Sheets API" → Enable.
# 3) Create a Service Account:
#    IAM & Admin → Service Accounts → Create Service Account.
#    Name it "dorinelpuia-form-writer". No roles needed at project level.
# 4) Create a JSON key: open the service account → Keys → Add Key →
#    JSON. A file like `dorinelpuia-form-writer-XXXXXX.json` downloads.
# 5) Open that JSON file and copy its ENTIRE content as a single line.
#    Paste below as the value of GOOGLE_SERVICE_ACCOUNT_JSON (keep the
#    surrounding single-quotes so newlines inside private_key stay intact).
#
# 6) Create a Google Sheet (sheets.google.com → New). Rename the tab to
#    "Submissions" (or whatever you set in GOOGLE_SHEETS_TAB below).
# 7) Copy the spreadsheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/<THIS_PART_IS_THE_ID>/edit
#    Paste it below as GOOGLE_SHEETS_ID.
# 8) SHARE the sheet with the service account email (looks like
#    `dorinelpuia-form-writer@<project>.iam.gserviceaccount.com`) — give
#    "Editor" access. Without this step, the API call will fail with 403.
#
# 9) The first submission auto-creates the header row in the sheet. You
#    do NOT need to add column names manually.

GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n","client_email":"dorinelpuia-form-writer@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'

GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=Submissions


# -----------------------------------------------------------------------------
# RESEND — transactional email
# -----------------------------------------------------------------------------
#
# HOW TO OBTAIN:
#
# 1) Sign up at https://resend.com/ (free: 3000 emails/mo).
# 2) Add your domain (dorinelpuia.ro) under Domains and configure the DNS
#    records Resend gives you. Without a verified domain you can still
#    send from "onboarding@resend.dev" for testing.
# 3) API Keys → Create API Key → scope "Sending access" → paste value below.
#
# EMAIL_FROM: the "From" address. Must be on a verified domain, or use
#   "onboarding@resend.dev" for testing. Format: "Name <addr@domain>".
# EMAIL_TO: comma-separated list of PRIMARY recipients (visible in the
#   "To:" header). Usually one address — the main inbox for inquiries.
#   Example: "dorinel@example.com"
# EMAIL_TO_BCC (optional): comma-separated list of BCC recipients (hidden
#   from "To:" recipients). Each gets the same email silently. Example:
#   "manager@example.com, agency@example.com"
# EMAIL_REPLY_TO (optional): reply-to address. Leave empty to default to
#   the sender's email from the form.

RESEND_API_KEY=re_
EMAIL_FROM=Dorinel Puia <contact@dorinelpuia.ro>
EMAIL_TO=
EMAIL_TO_BCC=
EMAIL_REPLY_TO=


# -----------------------------------------------------------------------------
# OPTIONAL — basic spam protection
# -----------------------------------------------------------------------------
# A simple shared secret that the frontend includes with the POST. The API
# rejects any submission that doesn't include it. Helps against automated
# bots hitting /api/submit directly. Pick any random string.
FORM_SECRET=
